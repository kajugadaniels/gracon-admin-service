<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin Account Invitation</title>
  <style>
    body{margin:0;padding:0;background:#f4f6f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
    .wrapper{max-width:580px;margin:40px auto;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,0.08)}
    .header{background:linear-gradient(135deg,#0f0f1f 0%,#1a1040 100%);padding:36px 40px;text-align:center}
    .header-badge{display:inline-block;background:rgba(91,35,255,0.25);border:1px solid rgba(91,35,255,0.50);border-radius:20px;padding:4px 14px;font-size:12px;font-weight:600;color:#a78bfa;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:16px}
    .header h1{color:#ffffff;font-size:24px;font-weight:700;margin:0;letter-spacing:-0.3px}
    .header p{color:rgba(255,255,255,0.55);font-size:13px;margin:8px 0 0}
    .body{padding:40px}
    .greeting{font-size:17px;color:#1a1a2e;font-weight:600;margin-bottom:10px}
    .text{font-size:14px;color:#555e6d;line-height:1.75;margin-bottom:24px}
    .info-box{background:#f8f7ff;border:1px solid #e0e0ff;border-radius:8px;padding:16px 20px;margin-bottom:28px}
    .info-row{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(0,0,0,0.06);font-size:13px}
    .info-row:last-child{border-bottom:none}
    .info-label{color:#6b7280;font-weight:500}
    .info-value{color:#1a1a2e;font-weight:600}
    .btn{display:block;width:fit-content;margin:0 auto 28px;padding:15px 40px;background:#5B23FF;color:#ffffff;text-decoration:none;border-radius:8px;font-size:15px;font-weight:700;letter-spacing:0.2px;box-shadow:0 4px 14px rgba(91,35,255,0.35)}
    .expires{text-align:center;font-size:12px;color:#9ca3af;margin-bottom:24px}
    .warn-box{background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:12px 16px;font-size:13px;color:#92400e;margin-bottom:24px;line-height:1.6}
    .divider{border:none;border-top:1px solid #f0f0f0;margin:0 0 24px}
    .fallback{font-size:12px;color:#9ca3af;line-height:1.6;word-break:break-all}
    .fallback a{color:#5B23FF}
    .footer{background:#f8f9fb;padding:20px 40px;text-align:center;font-size:12px;color:#9ca3af}
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <div class="header-badge">Admin Access</div>
      <h1>You have been invited</h1>
      <p>ID Verification Platform — Admin Panel</p>
    </div>

    <div class="body">
      <p class="greeting">Hello, {{firstName}} {{lastName}}</p>
      <p class="text">
        A SUPER_ADMIN has created an admin account for you on the
        <strong>ID Verification Platform</strong>. Click the button below
        to set your password and activate your account.
      </p>

      <!-- Account details summary -->
      <div class="info-box">
        <div class="info-row">
          <span class="info-label">Name</span>
          <span class="info-value">{{firstName}} {{lastName}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Email</span>
          <span class="info-value">{{email}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Role</span>
          <span class="info-value">Administrator</span>
        </div>
        <div class="info-row">
          <span class="info-label">Created by</span>
          <span class="info-value">{{createdByName}}</span>
        </div>
      </div>

      <a href="{{setPasswordUrl}}" class="btn">Set My Password &amp; Activate Account</a>

      <p class="expires">This invitation expires in {{expiresIn}}.</p>

      <div class="warn-box">
        <strong>Security notice:</strong> This link is single-use and
        expires in {{expiresIn}}. Never share it with anyone. If you did
        not expect this invitation, ignore this email — no account will
        be created without this link being used.
      </div>

      <hr class="divider"/>

      <p class="fallback">
        If the button does not work, copy and paste this link:<br/>
        <a href="{{setPasswordUrl}}">{{setPasswordUrl}}</a>
      </p>
    </div>

    <div class="footer">
      &copy; {{currentYear}} ID Verification Platform. All rights reserved.<br/>
      This email was sent because a SUPER_ADMIN added your email address as an administrator.
    </div>
  </div>
</body>
</html>
