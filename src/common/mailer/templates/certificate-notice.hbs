<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{title}}</title>
  <style>
    body{margin:0;padding:0;background:#f4f6f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
    .wrapper{max-width:580px;margin:40px auto;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,0.08)}
    .header{background:#101828;padding:34px 40px;text-align:center}
    .badge{display:inline-block;background:rgba(91,35,255,0.25);border:1px solid rgba(91,35,255,0.50);border-radius:20px;padding:4px 14px;font-size:12px;font-weight:700;color:#c4b5fd;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:16px}
    h1{color:#ffffff;font-size:24px;font-weight:700;margin:0}
    .body{padding:38px 40px}
    .greeting{font-size:17px;color:#1f2937;font-weight:700;margin:0 0 12px}
    .text{font-size:14px;color:#4b5563;line-height:1.75;margin:0 0 22px}
    .reason{background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;padding:16px 18px;margin:0 0 24px}
    .reason-label{display:block;color:#9a3412;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:8px}
    .reason-text{color:#7c2d12;font-size:14px;line-height:1.65;margin:0}
    .info{background:#f8f7ff;border:1px solid #e0e0ff;border-radius:8px;padding:14px 18px;margin-bottom:26px}
    .row{display:flex;justify-content:space-between;gap:18px;padding:6px 0;font-size:13px;border-bottom:1px solid rgba(0,0,0,0.06)}
    .row:last-child{border-bottom:none}
    .label{color:#6b7280;font-weight:600}
    .value{color:#111827;font-weight:700;text-align:right}
    .btn{display:block;width:fit-content;margin:0 auto;padding:14px 34px;background:#5B23FF;color:#ffffff;text-decoration:none;border-radius:8px;font-size:14px;font-weight:800}
    .footer{background:#f8f9fb;padding:20px 40px;text-align:center;font-size:12px;color:#9ca3af;line-height:1.6}
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <div class="badge">{{statusLabel}}</div>
      <h1>{{title}}</h1>
    </div>

    <div class="body">
      <p class="greeting">Hello, {{userName}}</p>
      <p class="text">{{summary}}</p>

      <div class="reason">
        <span class="reason-label">Administrator reason</span>
        <p class="reason-text">{{reason}}</p>
      </div>

      <div class="info">
        <div class="row">
          <span class="label">Action time</span>
          <span class="value">{{actionAt}}</span>
        </div>
        <div class="row">
          <span class="label">Where to review</span>
          <span class="value">Signature profile</span>
        </div>
      </div>

      <a href="{{signatureUrl}}" class="btn">Open Signature Profile</a>
    </div>

    <div class="footer">
      &copy; {{currentYear}} Gracon 360. This notice was sent because an administrator changed your certificate access state.
    </div>
  </div>
</body>
</html>
