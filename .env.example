# admin environment - managed by secret ownership cleanup.
# Keep this file key-compatible with the sibling .env files in this project.

# App
APP_PORT=3001
APP_ENV=development

# Runtime database
# Runtime access only. api/database owns migrations and seeds.
# Database role: gracon_admin_app
# Generate this role password with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# Deployment secret source: ADMIN_DATABASE_URL
DATABASE_URL=postgresql://gracon_admin_app:password@host/dbname?sslmode=require

# Admin JWT
# Deployment secret source: ADMIN_JWT_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=
ADMIN_JWT_ACCESS_EXPIRY=8h
ADMIN_JWT_REFRESH_EXPIRY=24h

# Shared identity encryption
# Must match api/auth ENCRYPTION_SECRET.
# Deployment secret source: PLATFORM_IDENTITY_ENCRYPTION_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_SECRET=

# Frontend and CORS
ADMIN_FRONTEND_URL=http://localhost:4001
USER_FRONTEND_URL=http://localhost:4000
FRONTEND_URLS=

# Mailer
# Deployment secret source: PLATFORM_SMTP_HOST
MAIL_HOST=
# Deployment secret source: PLATFORM_SMTP_PORT
MAIL_PORT=587
# Deployment secret source: PLATFORM_SMTP_USER
MAIL_USER=
# Deployment secret source: PLATFORM_SMTP_PASS
MAIL_PASS=
MAIL_FROM=

# Signature service bridge
# Deployment secret source: SIGNATURE_ADMIN_BRIDGE_URL
SIGNATURE_SERVICE_URL=http://localhost:3002/api/v1
# Deployment secret source: SIGNATURE_ADMIN_BRIDGE_USERNAME
SIGNATURE_SERVICE_USERNAME=service.signature-admin@yourplatform.com
# Deployment secret source: SIGNATURE_ADMIN_BRIDGE_PASSWORD
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
SIGNATURE_SERVICE_PASSWORD=

# Swagger docs basic auth
DOCS_BASIC_AUTH_USER=
# Deployment secret source: ADMIN_DOCS_BASIC_AUTH_PASS
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
DOCS_BASIC_AUTH_PASS=
