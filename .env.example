# ─── App ────────────────────────────────────────────────────────────────────
APP_PORT=3001
APP_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Same Neon Postgres as api/auth/ — admin service shares the database
# but NEVER runs prisma migrate — only prisma generate
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Admin JWT (completely separate from user JWT) ────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# This MUST be different from JWT_SECRET in api/auth/
ADMIN_JWT_SECRET=generate_a_completely_different_64_char_secret_here
ADMIN_JWT_ACCESS_EXPIRY=8h
ADMIN_JWT_REFRESH_EXPIRY=24h

# ─── Encryption ───────────────────────────────────────────────────────────────
# MUST be the exact same value as ENCRYPTION_SECRET in api/auth/
# Without this the admin service cannot decrypt NIDs and PIDs
ENCRYPTION_SECRET=same_32_char_secret_as_auth_service!!

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the admin frontend — primary origin allowed to call this service
ADMIN_FRONTEND_URL=http://localhost:4001
# Optional additional allowed origins, comma-separated.
# Leave empty unless another trusted frontend needs to call this admin API.
FRONTEND_URLS=

# ─── Mailer ───────────────────────────────────────────────────────────────────
# Used to send admin invite emails
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="ID Verify Admin <your_email@gmail.com>"

# ─── Swagger Docs (production protection) ────────────────────────────────────
DOCS_BASIC_AUTH_USER=your_admin_docs_username
DOCS_BASIC_AUTH_PASS=your_strong_docs_password