# admin .env.example - managed by Milestone 10 secret ownership cleanup.
# Keep this file key-compatible with the sibling .env files in this project.

# App
APP_PORT=3001
APP_ENV=development

# Runtime database
# Runtime access only. api/database owns migrations and seeds.
DATABASE_URL=

# Admin JWT
# Generate ADMIN_JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=
ADMIN_JWT_ACCESS_EXPIRY=8h
ADMIN_JWT_REFRESH_EXPIRY=24h

# Shared identity encryption
# Must match api/auth ENCRYPTION_SECRET.
ENCRYPTION_SECRET=

# Frontend and CORS
ADMIN_FRONTEND_URL=http://localhost:4001
USER_FRONTEND_URL=http://localhost:4000
FRONTEND_URLS=

# Mailer
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# Signature service bridge
# Generate SIGNATURE_SERVICE_PASSWORD with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
SIGNATURE_SERVICE_URL=http://localhost:3002/api/v1
SIGNATURE_SERVICE_USERNAME=service.signature-admin@yourplatform.com
SIGNATURE_SERVICE_PASSWORD=

# Swagger docs basic auth
# Generate DOCS_BASIC_AUTH_PASS with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
DOCS_BASIC_AUTH_USER=
DOCS_BASIC_AUTH_PASS=
